{
  "name": "@peerigon/fractals-typescript",
  "version": "0.0.0-semantically-released",
  "description": "Tiny helpers for TypeScript applications",
  "keywords": [],
  "homepage": "https://github.com/peerigon/fractals-typescript#readme",
  "bugs": {
    "url": "https://github.com/peerigon/fractals-typescript/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peerigon/fractals-typescript.git"
  },
  "license": "MIT",
  "author": "Peerigon GmbH <hello@peerigon.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./assert": "./dist/assert/assert.js",
    "./casing": "./dist/casing/index.js",
    "./dedupe": "./dist/dedupe/dedupe.js",
    "./enums": "./dist/enums/enums.js",
    "./errors": "./dist/errors/errors.js",
    "./match": "./dist/match/match.js",
    "./need": "./dist/need/need.js",
    "./reject": "./dist/reject/reject.js",
    "./result": "./dist/result/result.js",
    "./unwrap": "./dist/unwrap/unwrap.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "prepare": "husky",
    "test": "run-p test:*",
    "test:format": "prettier --check .",
    "test:lint": "eslint --max-warnings 0 --cache .",
    "test:types": "tsc",
    "test:unit": "vitest --run",
    "test:build": "run-s build test:build:*",
    "test:build:size": "size-limit",
    "vitest": "vitest",
    "build": "run-s build:*",
    "build:clear": "rimraf dist",
    "build:tsc": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@peerigon/configs": "^7.3.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "@tanstack/query-core": "^5.83.1",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.36.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "npm-run-all2": "^8.0.4",
    "pin-github-action": "^3.4.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "semantic-release": "^24.2.7",
    "size-limit": "^11.2.0",
    "typescript": "^5.9.2",
    "typescript-language-server": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
